public class Media {
    public static void main(String[] args) {
        int[] notas = {7, 8, 6, 10, 9};
        double soma = 0;
        for (int n : notas) soma += n;
        double media = soma / notas.length;

        int cont = 0;
        for (int n : notas) {
            if (n > media) cont++;
        }
        System.out.println("Média: " + media);
        System.out.println("Acima da média: " + cont);
    }
}


