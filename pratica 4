import java.util.Scanner;

public class Posto {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        double litros = sc.nextDouble();
        char tipo = sc.next().toUpperCase().charAt(0);
        double preco = 0;

        if (tipo == 'A') {
            preco = (litros <= 20) ? litros * 4.50 * 0.97 : litros * 4.50 * 0.95;
        } else if (tipo == 'G') {
            preco = (litros <= 20) ? litros * 6.00 * 0.96 : litros * 6.00 * 0.94;
        }
        
        System.out.printf("Valor: R$ %.2f%n", preco);
    }
}


