import java.util.Scanner;

public class projeto {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        System.out.print("Porcentagem da taxa de serviço: ");
        double taxa = sc.nextDouble();
        
        
        System.out.print("Valor unitário produto 1: ");
        double valor1 = sc.nextDouble();
        System.out.print("Quantidade produto 1: ");
        int quant1 = sc.nextInt();
        
        
        System.out.print("Valor unitário produto 2: ");
        double valor2 = sc.nextDouble();
        System.out.print("Quantidade produto 2: ");
        int quant2 = sc.nextInt();
        
        
        double total = (valor1 * quant1 + valor2 * quant2) * (taxa / 100 + 1);
        
        System.out.printf("Valor total com taxa: R$ %.2f%n", total);
        sc.close();
    }
}




    
