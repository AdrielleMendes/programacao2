public class b {
    public static void main(String[] args) {
        String s = "Computação";

        
        char primeiro = s.charAt(0);
        
    
        char terceiro = s.charAt(2);
        
        
        char ultimo = s.charAt(s.length() - 1);

        System.out.println("Palavra: " + s);
        System.out.println("Primeiro: " + primeiro);
        System.out.println("Terceiro: " + terceiro);
        System.out.println("Último: " + ultimo);
    }
}




