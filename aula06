import java.util.Scanner; 

public class Busca{
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);

        
        System.out.print("Digite uma frase: ");
        String frase = leitor.nextLine();

        
        System.out.print("Digite a palavra que deseja encontrar: ");
        String palavra = leitor.next();

        
        int posicao = frase.indexOf(palavra);

        
        if (posicao != -1) {
            System.out.println("A palavra foi encontrada no índice: " + posicao);
        } else {
            System.out.println("Resultado: " + posicao + " (Palavra não encontrada)");
        }

        leitor.close(); 
    }
}

